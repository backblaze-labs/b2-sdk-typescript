{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    // The SDK source uses bracket access for any Record<string,...> lookups
    // (`info['key']`), but example code looks much more natural with
    // `process.env.B2_APPLICATION_KEY_ID` than `process.env['B2_...']`. Relax
    // just this one rule for examples so they read like real user code.
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@backblaze/b2-sdk": ["../src/index.ts"],
      "@backblaze/b2-sdk/raw": ["../src/raw/index.ts"],
      "@backblaze/b2-sdk/errors": ["../src/errors/index.ts"],
      "@backblaze/b2-sdk/auth": ["../src/auth/index.ts"],
      "@backblaze/b2-sdk/auth/file": ["../src/auth/file.ts"],
      "@backblaze/b2-sdk/streams": ["../src/streams/index.ts"],
      "@backblaze/b2-sdk/sync": ["../src/sync/index.ts"],
      "@backblaze/b2-sdk/simulator": ["../src/simulator/index.ts"],
      "@backblaze/b2-sdk/s3": ["../src/s3/index.ts"]
    }
  },
  "include": [
    "node-list-buckets.ts",
    "node-upload.ts",
    "node-download.ts",
    "node-sync-cli.ts",
    "node-with-progress.ts",
    "node-backup-cli/**/*.ts",
    "node-plugin-template/**/*.ts"
  ],
  "exclude": ["../node_modules", "../dist"]
}
