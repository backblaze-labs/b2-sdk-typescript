{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "rootDir": "..",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    // The SDK source uses bracket access for any Record<string,...> lookups
    // (`info['key']`), but example code looks much more natural with
    // `process.env.B2_APPLICATION_KEY_ID` than `process.env['B2_...']`. Relax
    // just this one rule for examples so they read like real user code.
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@backblaze-labs/b2-sdk": ["../src/index.ts"],
      "@backblaze-labs/b2-sdk/raw": ["../src/raw/index.ts"],
      "@backblaze-labs/b2-sdk/errors": ["../src/errors/index.ts"],
      "@backblaze-labs/b2-sdk/auth": ["../src/auth/index.ts"],
      "@backblaze-labs/b2-sdk/auth/file": ["../src/auth/file.ts"],
      "@backblaze-labs/b2-sdk/streams": ["../src/streams/index.ts"],
      "@backblaze-labs/b2-sdk/sync": ["../src/sync/index.ts"],
      "@backblaze-labs/b2-sdk/simulator": ["../src/simulator/index.ts"],
      "@backblaze-labs/b2-sdk/s3": ["../src/s3/index.ts"]
    }
  },
  // `browser-uploader/`, `cloudflare-bandwidth-alliance/`, and
  // `react-native-presigned/` are intentionally excluded. Each depends on a
  // runtime-specific framework (Vite, Cloudflare Workers, React Native)
  // that the SDK doesn't ship as a devDependency. Their typecheck happens
  // via their own host tooling (vite, wrangler) at install time, not from
  // this tsconfig.
  "include": [
    "node-list-buckets.ts",
    "node-upload.ts",
    "node-download.ts",
    "node-sync-cli.ts",
    "node-with-progress.ts",
    "node-backup-cli/**/*.ts",
    "node-plugin-template/**/*.ts",
    "node-presigned-with-auth/**/*.ts"
  ],
  "exclude": ["../node_modules", "../dist"]
}
